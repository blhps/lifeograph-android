<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tv_month_name"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@color/t_mid"
        android:gravity="center"
        android:text="@string/placeholder"
        android:textColor="@color/t_lightest"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="12dp"
        app:layout_constraintEnd_toStartOf="@+id/gv_calendar"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toStartOf="parent" />

    <GridView
        android:id="@+id/gv_calendar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:columnWidth="128dp"
        android:listSelector="@drawable/selector_theme_colors"
        android:numColumns="7"
        android:stretchMode="columnWidth"
        android:verticalSpacing="8dp"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="5"
        app:layout_constraintStart_toEndOf="@id/tv_month_name"/>

</androidx.constraintlayout.widget.ConstraintLayout>
