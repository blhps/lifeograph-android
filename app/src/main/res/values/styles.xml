<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LifeoTheme" parent="Theme.Material3.Light">
        <item name="colorPrimary">@color/t_darker</item>
        <item name="colorSecondary">@color/t_lighter</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@color/t_lighter</item>
        <item name="buttonStyle">@style/LifeoButtonTheme</item>
        <item name="editTextStyle">@style/LifeoEditTextTheme</item>
        <item name="colorSurfaceVariant">@color/t_darkest</item>
        <item name="colorOutline">@android:color/white</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/t_lighter</item>
        <item name="colorSecondaryContainer">@color/t_lighter</item>
        <item name="colorOnPrimaryContainer">@android:color/white</item>
        <item name="colorOnSecondaryContainer">@android:color/white</item>
        <item name="colorSurface">@color/t_darkest</item>
        <item name="popupMenuStyle">@style/LifeoPopupMenu</item>
        <item name="android:popupMenuStyle">@style/LifeoPopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/LifeoPopupMenu</item>
    </style>

    <!-- FOR THE MAIN WINDOW -->
    <style name="LifeoTheme.NoActionBar" parent="LifeoTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="LifeoButtonTheme" parent="@style/Widget.AppCompat.Button.Borderless.Colored">
        <item name="android:textColor">@color/t_darkest</item>
    </style>

    <style name="LifeoEditTextTheme" parent="@style/Widget.AppCompat.EditText">
        <item name="android:textColor">@color/t_darkest</item>
    </style>

    <style name="LifeoAlertDlgTheme" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">@color/t_darker</item>
        <item name="colorSecondary">@color/t_lighter</item>
        <item name="colorSecondaryContainer">@color/t_lighter</item>
        <item name="colorOnSecondaryContainer">@android:color/white</item>
        <item name="colorSurfaceVariant">@color/t_darkest</item>
        <item name="colorOutline">@android:color/white</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:textColorPrimary">@color/t_lightest</item>
        <item name="android:background">@color/t_dark</item>
    </style>

    <style name="LifeoPopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@color/t_darkest</item>
    </style>

    <!--style name="LifeoTheme.TabStyle" parent="@style/Widget.AppCompat.ActionBar.TabView">
        <item name="background">@drawable/action_bar_tabs</item>
    </style-->

    <!--style name="LifeoTheme.SubtitleTextStyle"
           parent="@style/TextAppearance.AppCompat.Widget.ActionBar.Subtitle">
        <item name="android:textColor">@color/t_light</item>
    </style-->

    <style name="LifeoTheme.Widget" parent="@style/Theme.AppCompat.Light">
        <!--item name="android:popupMenuStyle">@style/PopupMenu.Lifeo</item-->
        <item name="android:dropDownListViewStyle">@style/LifeoTheme.DropDownListView</item>
    </style>

    <style name="LifeoTheme.DropDownListView"
           parent="@style/Widget.AppCompat.ListView.DropDown">
        <item name="android:listSelector">@drawable/selector_theme_colors_dark</item>
    </style>

    <!-- DIALOG STYLES -->
    <!--style name="FullHeightDialog" parent="LifeoTheme">
        <item name="android:windowNoTitle">true</item>
    </style-->

    <!-- TEXT STYLES -->
    <style name="boldText" parent="@android:style/TextAppearance.Medium">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="italicText" parent="@android:style/TextAppearance.Medium">
        <item name="android:textStyle">italic</item>
    </style>

    <style name="normalText" parent="@android:style/TextAppearance.Medium">
        <item name="android:textStyle">normal</item>
    </style>
    
    <style name="headingSpan" parent="@android:style/TextAppearance.Large">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">30sp</item>
    </style>
    
    <style name="subheadingSpan" parent="@android:style/TextAppearance.Large">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">25sp</item>
    </style>
    
    <style name="commentSpan" parent="@android:style/TextAppearance.Small">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="subscriptSpan" parent="@android:style/TextAppearance.Small">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFeatureSettings">"subs" 1</item>
    </style>
    <style name="superscriptSpan" parent="@android:style/TextAppearance.Small">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFeatureSettings">"sups" 1</item>
    </style>

</resources>
