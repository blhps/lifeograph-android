<RelativeLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:background="@drawable/selector_list_item"
android:baselineAligned="false"
android:orientation="horizontal">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status:"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:orientation="horizontal" >

        <net.sourceforge.lifeograph.ToggleImageButton
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:layout_weight=".2"
            android:id="@+id/btn_flt_status_not_todo"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/selector_entry" />

        <net.sourceforge.lifeograph.ToggleImageButton
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:layout_weight=".2"
            android:id="@+id/btn_flt_status_open"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/selector_todo_open" />

        <net.sourceforge.lifeograph.ToggleImageButton
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:layout_weight=".2"
            android:id="@+id/btn_flt_status_progressed"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/selector_todo_progressed" />

        <net.sourceforge.lifeograph.ToggleImageButton
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:layout_weight=".2"
            android:id="@+id/btn_flt_status_done"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/selector_todo_done" />

        <net.sourceforge.lifeograph.ToggleImageButton
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:layout_weight=".2"
            android:id="@+id/btn_flt_status_canceled"
            style="?android:attr/borderlessButtonStyle"
            android:src="@drawable/selector_todo_canceled" />

    </LinearLayout>

</RelativeLayout>
